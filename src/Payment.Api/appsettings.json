{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore.RateLimiting": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/payment-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithThreadId"]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PaymentDatabase": "Host=localhost;Port=5432;Database=payment_financial;Username=postgres;Password=;sslmode=Require;Maximum Pool Size=10"
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "zenyfin-api",
    "Audience": "zenyfin-payment",
    "AccessExpirationInMinutes": 15
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "UseSsl": false
  },
  "RateLimiting": {
    "Payment": {
      "PermitLimit": 10,
      "WindowInMinutes": 1,
      "QueueLimit": 2
    },
    "Strict": {
      "PermitLimit": 3,
      "WindowInMinutes": 1,
      "QueueLimit": 0
    }
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000"]
  }
}
