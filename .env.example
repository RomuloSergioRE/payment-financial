# Payment Financial - Environment Variables
# Copy this file to .env and fill in the values

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=
DB_NAME=payment_financial
DB_USE_SSL=false

# JWT (same secret as api-financial)
JWT_SECRET=
JWT_ISSUER=zenyfin-api
JWT_AUDIENCE=zenyfin-payment

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/
RABBITMQ_USE_SSL=false

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5001
